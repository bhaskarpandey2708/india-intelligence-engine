# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
!frontend/.env.production
venv/
.venv/
*.ipynb_checkpoints/

# Node.js
node_modules/
.next/
dist/
build/
.env.local
.env*.local

# Data - large files go to HuggingFace, not GitHub
data/raw/**/*.csv
data/raw/**/*.shp
data/raw/**/*.dbf
data/raw/**/*.shx
data/raw/**/*.prj
data/raw/**/*.cpg
data/raw/**/*.geojson
data/processed/**/*.geojson
data/processed/**/*.parquet
data/exports/**/*.parquet

# Keep schema/sample files
!data/**/*.sample.csv
!data/**/*.schema.json
!data/**/metadata.json

# Whitelist small runtime files needed by the API on Hostinger
# Census parquets (~507KB total — safe for git)
!data/exports/census_district_2011.parquet
!data/exports/census_state_2011.parquet
# Simplified GeoJSONs (~28MB total — safe for git)
!data/processed/geo_states_simplified.geojson
!data/processed/geo_districts_simplified.geojson
!data/processed/geo_subdistricts_simplified.geojson

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
