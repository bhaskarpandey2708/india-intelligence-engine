# Copy this to .env and fill in values

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=https://indiaintelligence.in,https://www.indiaintelligence.in

# Data directory (optional — defaults to ../data relative to api/)
# Set this if your data folder is at a different path on the server
# DATA_DIR=/home/u123456789/india-intelligence-engine/data
